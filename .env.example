# Environment variables for OpenEnv SQL Analyst
#
# Copy this file to .env and fill values as needed.
#   cp .env.example .env
#
# NOTE: Do not commit real tokens/keys.

# ------------------------------
# Mandatory for competition inference
# ------------------------------

# OpenAI-compatible API endpoint (defaults to HF router if unset)
API_BASE_URL=https://router.huggingface.co/v1

# Model identifier to use for inference (set this to your active model)
MODEL_NAME=gpt-4o-mini

# Hugging Face token / API key used as the OpenAI client api_key
# (leave blank here; set it in your environment or in a local .env)
HF_TOKEN=

# Only needed if you use openenv.from_docker_image() in your own tooling.
# The competition template expects this variable to exist.
LOCAL_IMAGE_NAME=

# ------------------------------
# Optional runtime knobs
# ------------------------------

# Which task to run in inference.py (defaults to sales_summary)
TASK_NAME=sales_summary

# Benchmark name printed in [START] (defaults to openenv-sql-analyst)
BENCHMARK=openenv-sql-analyst

# Max environment steps for one episode (defaults to 10)
MAX_STEPS=10

# Consider the episode successful if final score >= this threshold
SUCCESS_SCORE_THRESHOLD=0.10
